# =============================================================================
# 詐騙案件受理輔助系統 / Case Filing Assist
# Copy this file to `.env` and fill in the required values.
# 請複製為 `.env` 後填入必要設定。
# =============================================================================

# ── Required / 必填 ──────────────────────────────────────────────────────────

# MySQL connection string / MySQL 連線字串
# Example: mysql://user:password@localhost:3306/case_filing
DATABASE_URL=

# JWT session signing secret / JWT Session 簽章密鑰
# Use a long random value in production.
JWT_SECRET=

# ── LLM / OpenAI-compatible API ──────────────────────────────────────────────

# OpenAI-compatible base URL. For local DGX deployment, this can point to vLLM.
# OpenAI 相容 API 端點，例如 https://llm.example.com/v1
BUILT_IN_FORGE_API_URL=

# Bearer token for the LLM API / LLM API Bearer Token
BUILT_IN_FORGE_API_KEY=

# Model name sent in chat completions requests / 模型名稱
LLM_MODEL=gemma-4

# Maximum completion tokens / 最大輸出 token 數
LLM_MAX_TOKENS=4096

# ── App / 應用程式 ───────────────────────────────────────────────────────────

# Express server port / Express 伺服器 port
PORT=3000

# development or production
NODE_ENV=development

# Public app URL used for QR codes and OCR image loading.
# 對外網址，用於 QR Code 與 OCR 圖片讀取。
VITE_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Local upload storage directory / 本機上傳檔案目錄
LOCAL_STORAGE_DIR=./data/uploads

# ── OCR / Surya service ──────────────────────────────────────────────────────

# Surya OCR service URL used by the Node backend.
SURYA_SERVICE_URL=http://localhost:18765

# Port used when auto-starting the local Surya service.
SURYA_SERVICE_PORT=18765

# Set true to let the Node server auto-start surya-service/ocr_service.py.
# Production defaults to false when unset.
SURYA_AUTO_START=false

# ── Wallet APIs / 錢包查詢 API（可選，也可在系統設定頁輸入）────────────────────

ETHERSCAN_API_KEY=
TRONSCAN_API_KEY=

# ── Optional legacy OAuth settings / 可選舊 OAuth 設定 ───────────────────────

OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=police-case-filing
VITE_OAUTH_PORTAL_URL=
